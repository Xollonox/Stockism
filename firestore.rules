rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isAdmin() { 
      return isSignedIn() && 
             request.auth.token.email.lower() == "xolonox333@gmail.com".lower(); 
    }

    function isWorker() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "worker";
    }
    
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }
    
    match /game/{docId} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }
    
    match /news/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() || isWorker();
      allow delete: if isAdmin();
    }
    
    match /characters/{charId} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }
    
    match /users/{userId} { 
      allow read, write: if isAdmin() || isOwner(userId); 
      allow list: if isAdmin();
    }
    
    match /users_public/{userId} { 
      allow read: if true; 
      allow write: if isAdmin() || isOwner(userId); 
    }
    
    match /holdings/{userId} { 
      allow read, write: if isAdmin() || isOwner(userId);
      match /items/{itemId} { 
        allow read, write: if isAdmin() || isOwner(userId); 
      } 
    }
    
    match /trades/{tradeId} { 
      allow read: if true; 
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid; 
      allow write: if isAdmin();
    }
    
    match /daily_votes/{voteId} {
      allow read: if true;
      allow write: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }
    
    // 10. Chat - Read All, Signed-In Create
    match /chat/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /pools/{poolId} {
      allow read: if true;
      allow create: if isAdmin() || isWorker();
      allow update: if isAdmin() || isWorker();
      allow delete: if isAdmin();
      
      match /bets/{betId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
        allow read, write: if isAdmin() || isOwner(request.resource.data.uid);
      }
    }
  }
}
